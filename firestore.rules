rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && 
             request.auth.token.email == 'vishallko31@gmail.com';
    }
    
    match /content/{document=**} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    
    match /newsletter_subscribers/{subscriberId} {
      // Allow anyone (even unauthenticated) to create if email is present and non-empty
      allow create: if request.resource.data.email is string &&
                      request.resource.data.email.size() > 0 &&
                      (request.auth == null || request.auth != null);
      allow read, update, delete: if isAdmin();
    }
    
    match /blogs/{postId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    // Allow public comments but require moderation
    match /blog_comments/{commentId} {
      // Allow creating a comment if basic fields are present and approved is explicitly false
      allow create: if request.resource.data.blogId is string
                      && request.resource.data.name is string
                      && request.resource.data.name.size() > 0
                      && request.resource.data.comment is string
                      && request.resource.data.comment.size() > 0
                      && (request.resource.data.approved == false || !('approved' in request.resource.data));

      // Allow getting a single comment if it's approved or the requester is an admin
      allow get: if resource.data.approved == true || isAdmin();

      // Allow list queries if the client filters for approved==true, or if the requester is an admin
      allow list: if request.query.where('approved','==',true) || isAdmin();

      // Admins can update/delete (for approving or moderating)
      allow update, delete: if isAdmin();
    }

    match /blog_posts/{postId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /testimonials/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /training_logos/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /training_partners/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    
    match /courses/{courseId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /researchCourses/{courseId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    
    match /books/{bookId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }
    
    match /contact_submissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /trainings/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /research/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /training_programs/{docId} {
      allow read: if true;
      allow write, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
